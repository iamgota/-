دالة ترتيب_فقاعي(القائمة) {
  متغير ن = طول(القائمة)
  كرر من 0 حتى ن {
    كرر من 0 حتى ن - 1 {
      اذا (القائمة[ر] > القائمة[ر + 1]) {
        متغير مؤقت = القائمة[ر]
        القائمة[ر] = القائمة[ر + 1]
        القائمة[ر + 1] = مؤقت
      }
    }
  }
  ارجع القائمة
}

متغير االرقام = [90, 11, 22, 12, 25, 34, 64]
اطبع(ترتيب_فقاعي(االرقام))
